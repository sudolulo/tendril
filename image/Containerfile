# Tendril host image — a Fedora bootc OS with the GPU-passthrough virtualization stack and the
# tendril host binaries baked in. Build from the repo root:
#
#   podman build -f image/Containerfile -t tendril:dev .
#
# Then it can be deployed with `bootc` (bootc install / bootc switch). Base pinned in versions.toml.

# ---- build stage: compile the tendril binaries with the pinned toolchain ----
# Build on the same Fedora base as the runtime (matching glibc) and off Docker Hub (which rate-limits
# anonymous pulls). rust-toolchain.toml pins the version, so rustup installs exactly 1.84.0.
FROM quay.io/fedora/fedora-bootc:42 AS build
# In bootc images /root is a symlink to /var/roothome, which trips rustup's home-dir setup — install
# the toolchain under /usr/local instead (same layout the official rust image uses).
ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo PATH=/usr/local/cargo/bin:${PATH}
RUN dnf install -y --setopt=install_weak_deps=False gcc curl \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
       | sh -s -- -y --profile minimal --default-toolchain none --no-modify-path
WORKDIR /src
COPY . .
# Release binaries, locked to Cargo.lock.
RUN cargo build --release --locked

# ---- host image: Fedora bootc + virtualization stack ----
FROM quay.io/fedora/fedora-bootc:42

# Virtualization + passthrough userspace. VFIO itself is in the kernel; OVMF + swtpm cover the
# Secure Boot + TPM that Windows 11 guests require.
RUN dnf -y install \
        libvirt \
        libvirt-daemon-driver-qemu \
        qemu-kvm \
        edk2-ovmf \
        swtpm swtpm-tools \
        virt-install \
    && dnf clean all \
    && systemctl enable libvirtd.service

# IOMMU on + reserve vfio-pci early, via a bootc kernel-argument drop-in.
COPY image/kargs.d/00-tendril.toml /usr/lib/bootc/kargs.d/00-tendril.toml

# Load the VFIO modules at boot.
COPY image/vfio.conf /etc/modules-load.d/tendril-vfio.conf

# Tendril host binaries: detect -> plan -> apply, plus the station tooling (domain/vm/guest/usb).
COPY --from=build \
     /src/target/release/tendril-detect \
     /src/target/release/tendril-plan \
     /src/target/release/tendril-apply \
     /src/target/release/tendril-domain \
     /src/target/release/tendril-vm \
     /src/target/release/tendril-guest \
     /src/target/release/tendril-usb \
     /usr/bin/

LABEL org.opencontainers.image.source="https://git.onetick.ninja/flan/tendril"
LABEL org.opencontainers.image.description="Tendril — Fedora bootc host for GPU-passthrough gaming VMs"

# Sanity-check the bootc image at build time.
RUN bootc container lint
