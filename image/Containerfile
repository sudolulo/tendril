# Tendril host image — a Fedora bootc OS with the GPU-passthrough virtualization stack and the
# tendril host binaries baked in. Build from the repo root:
#
#   podman build -f image/Containerfile -t tendril:dev .
#
# Then it can be deployed with `bootc` (bootc install / bootc switch). Base pinned in versions.toml.

# ---- build stage: compile the tendril binaries with the pinned toolchain ----
# Build on the same Fedora base as the runtime (matching glibc) and off Docker Hub (which rate-limits
# anonymous pulls). rust-toolchain.toml pins the version, so rustup installs exactly 1.85.0.
FROM quay.io/fedora/fedora-bootc:42 AS build
# In bootc images /root is a symlink to /var/roothome, which trips rustup's home-dir setup — install
# the toolchain under /usr/local instead (same layout the official rust image uses).
ENV RUSTUP_HOME=/usr/local/rustup CARGO_HOME=/usr/local/cargo PATH=/usr/local/cargo/bin:${PATH}
RUN dnf install -y --setopt=install_weak_deps=False gcc curl \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
       | sh -s -- -y --profile minimal --default-toolchain none --no-modify-path
WORKDIR /src
COPY . .
# Release binaries, locked to Cargo.lock.
RUN cargo build --release --locked

# ---- host image: Fedora bootc + virtualization stack ----
FROM quay.io/fedora/fedora-bootc:42

# Virtualization + passthrough userspace. VFIO itself is in the kernel; OVMF + swtpm cover the
# Secure Boot + TPM that Windows 11 guests require.
RUN dnf -y install \
        libvirt \
        libvirt-daemon-driver-qemu \
        qemu-kvm \
        edk2-ovmf \
        swtpm swtpm-tools \
        virt-install \
        genisoimage \
        NetworkManager-tui \
        hwdata \
        greenboot greenboot-default-health-checks \
    && dnf clean all \
    && systemctl enable libvirtd.service \
    && { systemctl enable greenboot-healthcheck.service || true; }

# greenboot health-gated auto-rollback (the "can't-break-it" net): after any bootc update this check
# must pass or the bootloader falls back to the previous deployment. Ours asserts libvirt + the
# control plane are up (see the script header).
COPY image/greenboot/50-tendril-health.sh /usr/lib/greenboot/check/required.d/50-tendril-health.sh
RUN chmod +x /usr/lib/greenboot/check/required.d/50-tendril-health.sh

# Brand the OS as Tendril (keeps ID=fedora for package/tooling compatibility, à la other bootc
# spins). Surfaces in the installer summary, `bootc status`, and the login banner.
RUN sed -i \
        -e 's/^NAME=.*/NAME="Tendril"/' \
        -e 's/^PRETTY_NAME=.*/PRETTY_NAME="Tendril (Fedora bootc 42)"/' \
        -e '/^VARIANT=/d' -e '/^VARIANT_ID=/d' \
        /usr/lib/os-release \
    && printf 'VARIANT="Tendril"\nVARIANT_ID=tendril\n' >> /usr/lib/os-release

# IOMMU on + reserve vfio-pci early, via a bootc kernel-argument drop-in.
COPY image/kargs.d/00-tendril.toml /usr/lib/bootc/kargs.d/00-tendril.toml

# Load the VFIO modules at boot.
COPY image/vfio.conf /etc/modules-load.d/tendril-vfio.conf

# Tendril host binaries: the `tendril` console, the `tendril-web` control plane, detect -> plan ->
# apply, and the station tooling (domain/vm/guest/usb). tendril-web embeds its assets (htmx, noVNC).
COPY --from=build \
     /src/target/release/tendril \
     /src/target/release/tendril-web \
     /src/target/release/tendril-detect \
     /src/target/release/tendril-plan \
     /src/target/release/tendril-apply \
     /src/target/release/tendril-domain \
     /src/target/release/tendril-vm \
     /src/target/release/tendril-guest \
     /src/target/release/tendril-usb \
     /usr/bin/

# The web control plane, served on :80.
COPY image/web/tendril-web.service /usr/lib/systemd/system/tendril-web.service
RUN systemctl enable tendril-web.service

# Helper scripts the console can invoke (media fetch, installer build).
COPY scripts/ /usr/libexec/tendril/
RUN chmod +x /usr/libexec/tendril/*.sh

# vGPU build assets (Containerfiles) so the appliance can build a vGPU host-driver variant from its own
# running image + a driver staged in the web UI — no repo checkout needed.
COPY image/vgpu/ /usr/libexec/tendril/vgpu/

# Land in the Tendril console on the primary VT (appliance UX); other VTs / SSH get a normal shell.
COPY image/console/getty-autologin.conf /usr/lib/systemd/system/getty@tty1.service.d/autologin.conf
COPY image/console/tendril-console.sh /etc/profile.d/tendril-console.sh

# Boot-time hardware adaptation: snapshot the GPU capability matrix and flag IOMMU-off-in-BIOS (the one
# blocker Tendril can't fix itself) so the control plane can surface it on first boot.
COPY image/console/tendril-firstboot.sh /usr/libexec/tendril/tendril-firstboot.sh
COPY image/console/tendril-firstboot.service /usr/lib/systemd/system/tendril-firstboot.service
RUN chmod +x /usr/libexec/tendril/tendril-firstboot.sh \
    && systemctl enable tendril-firstboot.service

LABEL org.opencontainers.image.source="https://git.onetick.ninja/flan/tendril"
LABEL org.opencontainers.image.description="Tendril — Fedora bootc host for GPU-passthrough gaming VMs"

# Sanity-check the bootc image at build time.
RUN bootc container lint
